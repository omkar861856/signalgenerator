# Server Port
PORT=3005

# MongoDB Database Connection URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.wttchje.mongodb.net/signalgenerator?retryWrites=true&w=majority&appName=Cluster0

# Zerodha Kite Connect API Credentials (leave empty to use local simulation mode)
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret

# OpenAI API Key (leave empty if not calling live LLM models)
OpenAiApiKey=your_openai_api_key
